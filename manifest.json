{
    "manifest_version": 3,
    "name": "Subtext",
    "version": "1.0.0",
    "description": "Helps you read news articles more critically — AI summaries, loaded language signals, and fact-check links to dig deeper.",
    "icons": {
        "16": "icons/source.png",
        "32": "icons/source.png",
        "48": "icons/source.png",
        "128": "icons/source.png"
    },
    "permissions": [
        "sidePanel",
        "scripting",
        "storage",
        "favicon"
    ],
    "host_permissions": ["http://*/*", "https://*/*"],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_title": "Open Subtext",
        "default_icon": {
            "16": "icons/source.png",
            "32": "icons/source.png"
        }
    },
    "web_accessible_resources": [
        {
            "resources": ["_favicon/*"],
            "matches": ["http://*/*", "https://*/*"],
            "use_dynamic_url": true
        }
    ],
    "options_page": "options/options.html",
    "side_panel": {
        "default_path": "sidepanel/sidepanel.html"
    }
}